{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "blender": {
      "type": "local",
      "command": [
        "uvx",
        "blender-mcp"
      ],
      "enabled": true,
      "timeout": 300000
    },
    "SequentialThinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 10000
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "ls*": "allow",
      "pwd": "allow",
      "echo *": "allow"
    },
    "write": "allow"
  }
}